pipeline {
agent any

stages {

    stage('Checkout Code') {
        steps {
            echo 'Pulling code from GitHub...'
            checkout scm
        }
    }

    stage('Verify Files') {
        steps {
            echo 'Checking project structure...'
            sh 'ls -R'
        }
    }

    stage('HTML Check') {
        steps {
            echo 'Listing all HTML files...'
            sh 'find . -name "*.html"'
        }
    }

    stage('Build') {
        steps {
            echo 'No build needed for static website'
        }
    }

    stage('Test') {
        steps {
            echo 'Running basic tests...'
            sh 'echo "All tests passed"'
        }
    }

    stage('Deploy') {
        when {
            branch 'main'
        }
        steps {
            echo 'Deploying website...'
            sh 'mkdir -p deploy'
            sh 'cp -r PBA-1/* deploy/'
        }
    }

    stage('Finish') {
        steps {
            echo '🎉 MULTI-STAGE PIPELINE SUCCESS 🎉'
        }
    }
}

post {
    success {
        echo 'Pipeline completed successfully!'
    }
    failure {
        echo 'Pipeline failed! Check logs.'
    }
}

}
